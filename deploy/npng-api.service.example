[Unit]
Description=NP-NG FastAPI (uvicorn)
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/npng/backend
EnvironmentFile=/opt/npng/backend/.env
ExecStart=/opt/npng/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
