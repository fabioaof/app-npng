# API (FastAPI em Docker na porta 8000) — copiar para /etc/nginx/sites-available/api.nopain-nogain
# O cliente usa https://api.nopain-nogain.pt/api (prefixo /api no FastAPI).
#
# Se o certbot criou um bloco separado para :443, repete client_max_body_size nesse bloco também.

server {
    listen 80;
    listen [::]:80;
    server_name api.nopain-nogain.pt;

    # Predefinição do Nginx é 1m; o backend aceita fotos até 5MB (multipart tem overhead)
    client_max_body_size 6m;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
