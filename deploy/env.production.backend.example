# Alternativa: backend com systemd + Postgres no host (sem Docker).
# Para produção em Docker, usa deploy/env.docker.example junto a docker-compose.yml.

DATABASE_URL=postgresql+psycopg://npng:PASSWORD@127.0.0.1:5432/npng
JWT_SECRET=gerar-string-longa-e-aleatoria
CORS_ORIGINS=https://nopain-nogain.pt,https://www.nopain-nogain.pt
PUBLIC_BASE_URL=https://api.nopain-nogain.pt
UPLOAD_DIR=/var/www/nopain-nogain-api/uploads
