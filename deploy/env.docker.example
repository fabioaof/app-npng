# Copiar para /var/www/nopain-nogain-api/.env no servidor (não versionar segredos).
# Os valores de POSTGRES_* devem coincidir com a parte user:password@db:5432/dbname em DATABASE_URL.

POSTGRES_USER=npng
POSTGRES_PASSWORD=definir-password-forte
POSTGRES_DB=npng

DATABASE_URL=postgresql+psycopg://npng:definir-password-forte@db:5432/npng
JWT_SECRET=definir-string-longa-e-aleatoria
CORS_ORIGINS=https://nopain-nogain.pt,https://www.nopain-nogain.pt
# Origem onde o FastAPI expõe /media/ (fotos de perfil); tem de ser o host da API, não o site estático.
PUBLIC_BASE_URL=https://api.nopain-nogain.pt
