# BD local: copia para .env.
# Só Postgres no host: npng@localhost:5432
# API+Postgres em Docker (compose): usa DATABASE_URL com host "db" só dentro do container; no host continua localhost:5432 para ferramentas locais.
DATABASE_URL=postgresql+psycopg://npng:npng@localhost:5432/npng
JWT_SECRET=change-me-to-a-long-random-string
# Origens do frontend em dev (ajusta a tua porta, ex. Quasar em 8090)
CORS_ORIGINS=http://localhost:9000,http://127.0.0.1:9000,http://localhost:8090,http://127.0.0.1:8090
PUBLIC_BASE_URL=http://127.0.0.1:8000
UPLOAD_DIR=./uploads
